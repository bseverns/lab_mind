TZ=America/Chicago

# Service ports
PORTAINER_PORT=9443
OPENWEBUI_PORT=3000
NODERED_PORT=1880
SYNCTHING_GUI_PORT=8384
CNCJS_PORT=8000

# Data roots on NVMe-backed storage
JETSON_DATA_ROOT=/srv/jetson
OLLAMA_DATA=/srv/jetson/ollama
OPENWEBUI_DATA=/srv/jetson/openwebui
PORTAINER_DATA=/srv/jetson/portainer
NODERED_DATA=/srv/jetson/nodered
SYNCTHING_DATA=/srv/jetson/syncthing
CNCJS_DATA=/srv/jetson/cncjs

# Optional CNC serial path
CNC_SERIAL_DEVICE=/dev/ttyUSB0

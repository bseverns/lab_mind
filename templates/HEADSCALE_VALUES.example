# Headscale / Tailnet Values for Lab-Brain
# Copy to a private file before filling secrets.

HEADSCALE_SERVER_URL=https://hs.creatempls.org
HEADSCALE_BASE_DOMAIN=tail.creatempls.org
HEADSCALE_ENROLLMENT_METHOD=EDIT_ME_preauth_key_or_interactive
HEADSCALE_PREAUTH_KEY=DO_NOT_COMMIT_REAL_KEY

JETSON_A_HOSTNAME=labbrain-a
JETSON_A_TAILNET_NAME=labbrain-a
JETSON_A_TAGS=tag:ops,tag:model

JETSON_B_HOSTNAME=labbrain-b
JETSON_B_TAILNET_NAME=labbrain-b
JETSON_B_TAGS=tag:ops

JETSON_C_HOSTNAME=labbrain-c
JETSON_C_TAILNET_NAME=labbrain-c
JETSON_C_TAGS=tag:ops,tag:docs

EDUCATOR_DEVICE_POLICY=trusted_staff_only
PUBLIC_PORT_FORWARDING_ALLOWED=0
